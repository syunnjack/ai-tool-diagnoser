---
import Layout from '../layouts/Layout.astro';
import { questions } from '../data/questions';
import { tools } from '../data/tools';

const websiteJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'AIツール診断',
  url: Astro.site,
  description: '5つの質問であなたに合うAIツールを診断できる情報サイト。',
  inLanguage: 'ja',
});
---

<Layout
  title="AIツール診断 | 5つの質問であなたに合うAIツールがわかる"
  description="5つの質問に答えるだけで、あなたの目的・予算・レベルに合ったAIツールを診断します。文章生成、画像生成、コード補助など目的別におすすめを提案します。"
>
  <script slot="head" type="application/ld+json" set:html={websiteJsonLd} />

  <section class="hero">
    <h1>AIツール診断</h1>
    <p>5つの質問に答えるだけで、あなたに合うAIツールを提案します。</p>
  </section>

  <section id="quiz-section" class="card">
    <div class="progress-wrap">
      <div id="progress-text">質問 1 / {questions.length}</div>
      <div class="progress-bar"><div id="progress-fill"></div></div>
    </div>

    <div id="question-container"></div>

    <div class="actions">
      <button id="prev-btn" class="btn btn-secondary" disabled>戻る</button>
      <button id="next-btn" class="btn btn-primary" disabled>次へ</button>
    </div>
  </section>

  <section class="intro-text">
    <h2>このサイトについて</h2>
    <p>
      世の中には数え切れないほどのAIツールがあり、「結局どれを使えばいいの？」と迷う人は少なくありません。
      このサイトでは、目的・予算・利用レベル・頻度・シーンの5つの質問から、あなたに合うタイプのAIツールをスコアリングして提案します。
      診断結果には、実際に使った人の口コミもあわせて掲載しています。
    </p>
  </section>
</Layout>

<script define:vars={{ questions, tools }}>
  const questionContainer = document.getElementById('question-container');
  const nextBtn = document.getElementById('next-btn');
  const prevBtn = document.getElementById('prev-btn');
  const progressText = document.getElementById('progress-text');
  const progressFill = document.getElementById('progress-fill');

  let currentQuestionIndex = 0;
  let answers = new Array(questions.length).fill(null);

  function renderQuestion() {
    const question = questions[currentQuestionIndex];

    progressText.textContent = `質問 ${currentQuestionIndex + 1} / ${questions.length}`;
    progressFill.style.width = `${((currentQuestionIndex + 1) / questions.length) * 100}%`;

    questionContainer.innerHTML = `
      <h2 class="question-title">${question.title}</h2>
      <div class="options">
        ${question.options
          .map((option, index) => {
            const selected = answers[currentQuestionIndex] === index ? 'selected' : '';
            return `<div class="option ${selected}" data-index="${index}">${option.label}</div>`;
          })
          .join('')}
      </div>
    `;

    questionContainer.querySelectorAll('.option').forEach((el) => {
      el.addEventListener('click', () => {
        answers[currentQuestionIndex] = Number(el.dataset.index);
        renderQuestion();
      });
    });

    prevBtn.disabled = currentQuestionIndex === 0;
    nextBtn.disabled = answers[currentQuestionIndex] === null;
    nextBtn.textContent = currentQuestionIndex === questions.length - 1 ? '結果を見る' : '次へ';
  }

  function collectSelectedTags() {
    const selectedTags = [];
    questions.forEach((question, qIndex) => {
      const answerIndex = answers[qIndex];
      if (answerIndex !== null) {
        selectedTags.push(...question.options[answerIndex].tags);
      }
    });
    return selectedTags;
  }

  function scoreTools(selectedTags) {
    return tools
      .map((tool) => {
        let score = 0;
        selectedTags.forEach((tag) => {
          if (tool.tags.includes(tag)) score += 1;
        });
        return { ...tool, score };
      })
      .sort((a, b) => b.score - a.score);
  }

  function goToResult() {
    const selectedTags = collectSelectedTags();
    const ranked = scoreTools(selectedTags);
    const best = ranked[0];
    const runnersUp = ranked.slice(1, 3).map((t) => t.slug);
    const params = new URLSearchParams({ also: runnersUp.join(',') });
    window.location.href = `/result/${best.slug}/?${params.toString()}`;
  }

  nextBtn.addEventListener('click', () => {
    if (answers[currentQuestionIndex] === null) return;
    if (currentQuestionIndex < questions.length - 1) {
      currentQuestionIndex += 1;
      renderQuestion();
    } else {
      goToResult();
    }
  });

  prevBtn.addEventListener('click', () => {
    if (currentQuestionIndex > 0) {
      currentQuestionIndex -= 1;
      renderQuestion();
    }
  });

  renderQuestion();
</script>

<style>
  .hero {
    text-align: center;
    margin-bottom: 1.5rem;
  }
  .hero h1 {
    font-size: 1.8rem;
    margin-bottom: 0.5rem;
  }
  .hero p {
    color: var(--color-muted);
  }
  .progress-wrap {
    margin-bottom: 1.5rem;
  }
  #progress-text {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin-bottom: 0.4rem;
  }
  .progress-bar {
    background: #e2e8f0;
    border-radius: 999px;
    height: 8px;
    overflow: hidden;
  }
  #progress-fill {
    background: var(--color-primary);
    height: 100%;
    width: 20%;
    transition: width 0.2s ease;
  }
  .question-title {
    font-size: 1.15rem;
    margin-bottom: 1rem;
  }
  .options {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .option {
    border: 2px solid #e2e8f0;
    border-radius: var(--radius);
    padding: 0.9rem 1rem;
    cursor: pointer;
    transition: border-color 0.15s ease, background 0.15s ease;
  }
  .option:hover {
    border-color: var(--color-primary);
  }
  .option.selected {
    border-color: var(--color-primary);
    background: #eef2ff;
    font-weight: 700;
  }
  .actions {
    display: flex;
    justify-content: space-between;
    margin-top: 1.5rem;
    gap: 0.75rem;
  }
  .actions .btn {
    flex: 1;
  }
  .intro-text {
    margin-top: 2.5rem;
    font-size: 0.9rem;
    color: var(--color-muted);
  }
  .intro-text h2 {
    font-size: 1.1rem;
    color: var(--color-text);
  }
</style>
